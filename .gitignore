target/
# apps/buffr-stub is excluded from the workspace (it owns the `buffr`
# crates.io name; the bin output collides with the real binary), so
# it has its own target/ that the root `/target` rule misses.
/apps/buffr-stub/target
**/*.rs.bk
*.pdb

# Build-time downloads (CEF binary tree, packaging tools, etc.) —
# never vendored into git.
/vendor/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# mdBook output — regenerated from `docs/` on every CI run; not
# committed because the source markdown is the canonical text.
/docs-site

# Flatpak build state. CI copies the icon + tarball payload in
# before invoking flatpak-builder; both are ignored to keep the
# tree clean for local rebuilds.
/flatpak/build
/flatpak/repo
/flatpak/payload
/flatpak/buffr-*.tar.gz
/flatpak/buffr-*.flatpak
/flatpak/buffr-*.flatpak.sha256
/flatpak/sh.kryptic.buffr.png
/flatpak/sh.kryptic.buffr.desktop
/flatpak/.flatpak-builder

# Snap build state.
/snap/payload
/snap/buffr-*.tar.gz
/buffr-*.snap
/buffr-*.snap.sha256

